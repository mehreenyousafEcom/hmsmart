"kl-trust-badge\" role=\"listitem\" aria-label=\"Money-Back Guarantee\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <path d=\"M12 2a10 10 0 100 20 10 10 0 000-20zm.5 4v1.2c1.8.2 3 1.2 3 2.7 0 1.7-1.4 2.4-3.2 2.8-1.7.4-2 .7-2 .9 0 .3.3.6 1 .7v1.2h1.4V15c1.8-.1 3.1-1.1 3.2-2.7h-1.5c-.1.7-.7 1.3-1.7 1.5v-2c1.8-.4 3.3-1 3.3-2.9 0-1.7-1.4-2.7-3.1-2.9V6h-1.4z\"\/>\n      <\/svg>\n      <span>Money-Back Guarantee<\/span>\n    <\/div>\n  <\/div>\n<\/div>"}},"custom_liquid_KNTn7z":{"type":"custom_liquid","settings":{"custom_liquid":"<style>\n.hm-sale-timer {\n  max-width: 720px;\n  margin: 20px auto;\n  background: #f7f2fb;\n  border: 2px dashed #9C7EBB;\n  border-radius: 14px;\n  padding: 14px 18px;\n  font-family: Arial, sans-serif;\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  box-shadow: 0 4px 14px rgba(156,126,187,0.25);\n}\n\n.hm-sale-icon {\n  font-size: 22px;\n}\n\n.hm-sale-text {\n  font-size: 15px;\n  color: #4b3765;\n  font-weight: 600;\n}\n\n.hm-sale-text span {\n  color: #9C7EBB;\n  font-weight: 800;\n}\n\n.hm-timer {\n  margin-left: auto;\n  font-size: 15px;\n  font-weight: 700;\n  color: #9C7EBB;\n  letter-spacing: 0.5px;\n}\n\n@media(max-width:520px){\n  .hm-sale-timer {\n    flex-direction: column;\n    text-align: center;\n  }\n  .hm-timer {\n    margin-left: 0;\n  }\n}\n<\/style>\n\n<div class=\"hm-sale-timer\">\n  <div class=\"hm-sale-icon\">⏰<\/div>\n  <div class=\"hm-sale-text\">\n    Sale ends in <span id=\"hmSaleText\">soon<\/span>\n  <\/div>\n  <div class=\"hm-timer\" id=\"hmSaleTimer\">00h 00m 00s<\/div>\n<\/div>\n\n<script>\n\/* ==============================\n   NEVER-EXPIRING SALE TIMER\n   (Auto resets daily)\n============================== *\/\n\nfunction hmStartTimer() {\n\n  \/\/ Always set sale to end at 11:59 PM Pakistan Time\n  const now = new Date();\n  const utc = now.getTime() + (now.getTimezoneOffset() * 60000);\n  const pkNow = new Date(utc + (5 * 60 * 60 * 1000));\n\n  const end = new Date(pkNow);\n  end.setHours(23, 59, 59, 999);\n\n  function updateTimer() {\n    const current = new Date();\n    const utcNow = current.getTime() + (current.getTimezoneOffset() * 60000);\n    const pkCurrent = new Date(utcNow + (5 * 60 * 60 * 1000));\n\n    let diff = end - pkCurrent;\n\n    \/\/ If expired → auto reset to next day\n    if (diff <= 0) {\n      hmStartTimer();\n      return;\n    }\n\n    const h = Math.floor(diff \/ (1000 * 60 * 60));\n    const m = Math.floor((diff % (1000 * 60 * 60)) \/ (1000 * 60));\n    const s = Math.floor((diff % (1000 * 60)) \/ 1000);\n\n    document.getElementById(\"hmSaleTimer\").textContent =\n      `${h}h ${m}m ${s}s`;\n  }\n\n  updateTimer();\n  setInterval(updateTimer, 1000);\n}\n\nhmStartTimer();\n<\/script>"}},"custom_liquid_xbFkPQ":{"type":"custom_liquid","settings":{"custom_liquid":"<style>\n.hm-courier-box {\n  max-width: 700px;\n  margin: 25px auto;\n  background: #9C7EBB;\n  color: #fff;\n  border-radius: 16px;\n  padding: 16px 18px;\n  font-family: Arial, sans-serif;\n  box-shadow: 0 6px 18px rgba(156,126,187,0.45);\n}\n\n.hm-courier-top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  font-size: 14px;\n  font-weight: 600;\n  margin-bottom: 12px;\n}\n\n.hm-cod-badge {\n  background: #fff;\n  color: #6b4b8f;\n  padding: 4px 10px;\n  border-radius: 20px;\n  font-size: 12px;\n  font-weight: 700;\n}\n\n.hm-track-row {\n  display: flex;\n  justify-content: space-between;\n  background: rgba(255,255,255,0.18);\n  padding: 14px;\n  border-radius: 12px;\n  margin-bottom: 12px;\n}\n\n.hm-step {\n  text-align: center;\n  flex: 1;\n  position: relative;\n}\n\n.hm-step:not(:last-child):after {\n  content: '';\n  position: absolute;\n  right: -10px;\n  top: 18px;\n  width: 20px;\n  height: 2px;\n  background: rgba(255,255,255,0.6);\n}\n\n.hm-icon {\n  font-size: 22px;\n  margin-bottom: 6px;\n}\n\n.hm-step span {\n  display: block;\n  font-size: 12px;\n}\n\n.hm-live-text {\n  text-align: center;\n  font-size: 14px;\n  margin-bottom: 10px;\n  animation: blink 1.4s infinite;\n}\n\n@keyframes blink {\n  0% { opacity: 1; }\n  50% { opacity: 0.4; }\n  100% { opacity: 1; }\n}\n\n.hm-track-btn {\n  display: block;\n  text-align: center;\n  background: #fff;\n  color: #6b4b8f;\n  padding: 10px;\n  border-radius: 10px;\n  font-weight: 700;\n  text-decoration: none;\n}\n.hm-track-btn:hover {\n  background: #f3ebff;\n}\n<\/style>\n\n<div class=\"hm-courier-box\">\n\n  <div class=\"hm-courier-top\">\n    <div>🚚 HM Express Courier<\/div>\n    <div class=\"hm-cod-badge\">✔ COD VERIFIED<\/div>\n  <\/div>\n\n  <div class=\"hm-track-row\">\n    <div class=\"hm-step\">\n      <div class=\"hm-icon\">📦<\/div>\n      <span>Ordered<\/span>\n      <span id=\"orderDate\"><\/span>\n    <\/div>\n\n    <div class=\"hm-step\">\n      <div class=\"hm-icon\">✈️<\/div>\n      <span>Shipped<\/span>\n      <span id=\"shipDate\"><\/span>\n    <\/div>\n\n    <div class=\"hm-step\">\n      <div class=\"hm-icon\">🏠<\/div>\n      <span>Delivered<\/span>\n      <span id=\"deliveryDate\"><\/span>\n    <\/div>\n  <\/div>\n\n  <div class=\"hm-live-text\">\n    🔴 Live shipment to <strong><span id=\"cityName\"><\/span><\/strong>\n  <\/div>\n\n  <a class=\"hm-track-btn\"\n     href=\"https:\/\/wa.me\/923021143129?text=Hi%20HMsmart%2C%20I%20want%20to%20track%20my%20order\">\n     📲 Track Order on WhatsApp\n  <\/a>\n\n<\/div>\n\n<script>\n\/\/ Rotate cities\nconst cities = [\"Lahore\", \"Karachi\", \"Islamabad\"];\nlet cityIndex = 0;\n\nfunction rotateCity() {\n  document.getElementById(\"cityName\").textContent = cities[cityIndex];\n  cityIndex = (cityIndex + 1) % cities.length;\n}\nrotateCity();\nsetInterval(rotateCity, 4000);\n\n\/\/ Dynamic Dates\nfunction updateDates() {\n  const today = new Date();\n  const options = { day: '2-digit', month: 'short' };\n\n  \/\/ Ordered = 2 days ago\n  const orderDate = new Date(today);\n  orderDate.setDate(today.getDate() - 2);\n  document.getElementById(\"orderDate\").textContent = orderDate.toLocaleDateString('en-GB', options);\n\n  \/\/ Shipped = 1 day ago\n  const shipDate = new Date(today);\n  shipDate.setDate(today.getDate() - 1);\n  document.getElementById(\"shipDate\").textContent = shipDate.toLocaleDateString('en-GB', options);\n\n  \/\/ Delivered = 2 days ahead\n  const deliveryDate = new Date(today);\n  deliveryDate.setDate(today.getDate() + 2);\n  document.getElementById(\"deliveryDate\").textContent = deliveryDate.toLocaleDateString('en-GB', options);\n}\n\n\/\/ Initial call\nupdateDates();\n\n\/\/ Update every 1 minute to keep dates always correct (even if browser is open long time)\nsetInterval(updateDates, 60000);\n<\/script>"}},"variant-picker":{"type":"variant_picker","settings":{"picker_type":"button","swatch_shape":"circle"}},"quantity-selector":{"type":"quantity_selector","settings":{}},"buy_buttons":{"type":"buy_buttons","settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"custom_liquid_XCaBCR":{"type":"custom_liquid","settings":{"custom_liquid":"<!-- Pay & Save Button -->\n<div class=\"pay-save-wrapper\">\n  <button id=\"paySaveBtn\" class=\"pay-save-btn\">Pay & Save 10% (Advance Payment)<\/button>\n\n  <div id=\"paySavePopup\" class=\"pay-save-popup\">\n    <p>Original Price: <span class=\"original-price\">Rs.{{ product.price | divided_by: 100 }} PKR<\/span><\/p>\n    <p>Discounted Price: <span class=\"discounted-price\">Rs.{{ product.price | times: 0.9 | round | divided_by: 100 }} PKR<\/span><\/p>\n\n    <p><strong>Bank Name:<\/strong> UBL<\/p>\n    <p><strong>Account Title:<\/strong> Mahreen Yousaf <\/p>\n    <p><strong>Account Number:<\/strong> 1538328289402<\/p>\n    <p><strong>IBAN:<\/strong> PK34UNIL0109000328289402<\/p>\n\n    <p>Send Screenshot \/ Video to complete payment:<\/p>\n\n    <a href=\"#\" target=\"_blank\" class=\"whatsapp-button\">Send Screenshot \/ Video via WhatsApp<\/a>\n\n    <span class=\"popup-close\">&times;<\/span>\n  <\/div>\n<\/div>\n\n<style>\n.pay-save-wr