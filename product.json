= r.img;\n  index = (index + 1) % reviews.length;\n}\n\nrotateReview();\nsetInterval(rotateReview, 4000);\n<\/script>"}},"custom_liquid_E3pQYC":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<style>\n.hm-customer-badge {\n  background: #9C7EBB; \/* Your store color *\/\n  padding: 16px;\n  border-radius: 10px;\n  text-align: center;\n  color: #fff;\n  font-weight: 700;\n  font-size: 18px;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 8px;\n  box-shadow: 0 3px 12px rgba(0,0,0,0.12);\n}\n\n.hm-customer-badge span {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 18px;\n}\n<\/style>\n\n<div class=\"hm-customer-badge\">\n  <span>❤️ 10,000+ HAPPY CUSTOMERS 😊<\/span>\n<\/div>"}},"custom_liquid_L7nGKw":{"type":"custom_liquid","settings":{"custom_liquid":"<!-- ⭐ HMSMART SINGLE SLIDING PRODUCT BADGE ⭐ -->\n<style>\n.hm-badge-box {\n  width: 100%;\n  padding: 14px 20px;\n  background: #8a60c2;\n  color: #fff;\n  font-size: 18px;\n  font-weight: 700;\n  border-radius: 12px;\n  text-align: center;\n  margin: 12px 0;\n  box-shadow: 0 0 12px rgba(0,0,0,0.18);\n  animation: hmHighlightPulse 2s infinite ease-in-out;\n}\n\n@keyframes hmHighlightPulse {\n  0% { box-shadow: 0 0 0px rgba(140, 96, 194, 0.4); }\n  50% { box-shadow: 0 0 15px rgba(140, 96, 194, 0.8); }\n  100% { box-shadow: 0 0 0px rgba(140, 96, 194, 0.4); }\n}\n\n.hm-badge-box span {\n  transition: opacity 0.4s ease;\n}\n<\/style>\n\n<div class=\"hm-badge-box\">\n  <span id=\"hm-slide-text\">👀 100 People Are Viewing This Product<\/span>\n<\/div>\n\n<script>\nlet slideIndex = 0;\nlet viewerCount = 100;\n\nconst slides = [\n  () => `👀 ${viewerCount} People Are Viewing This Product`,\n  () => `💖 Trusted by Thousands of Happy Customers`,\n  () => `🚚 Fast Delivery All Over Pakistan`,\n  () => `💸 Cash on Delivery Available`\n];\n\nfunction updateBadge() {\n  viewerCount = 90 + Math.floor(Math.random() * 40); \/\/ 90–130 viewers\n  document.getElementById(\"hm-slide-text\").style.opacity = \"0\";\n\n  setTimeout(() => {\n    document.getElementById(\"hm-slide-text\").innerHTML = slides[slideIndex]();\n    document.getElementById(\"hm-slide-text\").style.opacity = \"1\";\n    slideIndex = (slideIndex + 1) % slides.length;\n  }, 400);\n}\n\nupdateBadge();\nsetInterval(updateBadge, 4000);\n<\/script>"}},"easyreviews_star_rating_cDrTCf":{"type":"shopify:\/\/apps\/easyreviews\/blocks\/star_rating\/1341251b-09d7-46f3-ba6a-e732a50e97a5","settings":{"product":"{{product}}"}},"vendor":{"type":"text","settings":{"text":"{{ product.vendor }}","text_style":"uppercase"}},"title":{"type":"title","settings":{}},"price":{"type":"price","settings":{}},"custom_liquid_wUYJHb":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<style>\n.custom-cod-box {\n  background:#fff;\n  padding:25px;\n  border-radius:12px;\n  box-shadow:0 0 12px rgba(0,0,0,0.08);\n  margin-top:20px;\n}\n.custom-cod-box input, .custom-cod-box textarea, .custom-cod-box select {\n  width:100%;\n  padding:12px;\n  border:1px solid #ddd;\n  border-radius:6px;\n  margin-bottom:15px;\n  font-size:15px;\n}\n.custom-cod-box button {\n  background:#9C7EBB;\n  color:#fff;\n  padding:14px;\n  border:none;\n  border-radius:6px;\n  width:100%;\n  font-size:16px;\n  cursor:pointer;\n}\n.price-box { font-size:22px; margin-bottom:15px; }\n.discount-box { margin-bottom:10px; font-size:18px; color:#9C7EBB; font-weight:600; }\n.delivery-info { color:#9C7EBB; font-weight:600; margin-bottom:15px; }\n.whatsapp-info { margin-bottom:25px; font-size:16px; }\n.success-msg {\n  display:none;\n  background:#e8ffe8;\n  padding:15px;\n  border-radius:6px;\n  margin-top:15px;\n  color:#0a8a0a;\n  font-weight:600;\n}\n<\/style>\n\n<div class=\"custom-cod-box\">\n\n  <!-- PRICE -->\n  <div class=\"price-box\">\n    {% if product.compare_at_price > product.price %}\n      <span class=\"old-price\">Rs{{ product.compare_at_price | money_without_currency }}<\/span>\n    {% endif %}\n    <span class=\"new-price\" id=\"basePrice\" data-price=\"{{ product.price | money_without_currency }}\">\n      Rs{{ product.price | money_without_currency }}\n    <\/span>\n  <\/div>\n\n  <div class=\"discount-box\" id=\"discountBox\">You Save: Rs0<\/div>\n  <div class=\"discount-box\" id=\"finalPriceBox\">Final Price: Rs{{ product.price | money_without_currency }}<\/div>\n\n  <div class=\"delivery-info\">Delivery: <b>Free 🚚<\/b><\/div>\n  <div class=\"whatsapp-info\">WhatsApp Support: <b>0302-1143129<\/b><\/div>\n\n  <form id=\"codForm\">\n    <label>Select Variant:<\/label>\n    <select name=\"variant_id\" id=\"variantSelect\" required>\n      {% for variant in product.variants %}\n      <option value=\"{{ variant.id }}\" data-price=\"{{ variant.price | money_without_currency }}\">\n        {{ variant.title }} - Rs{{ variant.price | money_without_currency }}\n      <\/option>\n      {% endfor %}\n    <\/select>\n\n    <label>Quantity:<\/label>\n    <select name=\"quantity\" id=\"quantityBox\">\n      {% for i in (1..10) %}\n      <option value=\"{{ i }}\">{{ i }}<\/option>\n      {% endfor %}\n    <\/select>\n\n    <label>Full Name:<\/label>\n    <input type=\"text\" name=\"name\" required>\n\n    <label>Phone Number:<\/label>\n    <input type=\"text\" name=\"phone\" required>\n\n    <label>Complete Address:<\/label>\n    <textarea name=\"address\" required><\/textarea>\n\n    <button type=\"submit\">PLACE ORDER<\/button>\n  <\/form>\n\n  <div class=\"success-msg\" id=\"successMsg\">\n    ✅ Order Placed Successfully!  \n    We will contact you soon.\n  <\/div>\n<\/div>\n\n<script>\nfunction updatePricing() {\n  const qty = parseInt(document.getElementById(\"quantityBox\").value);\n  const variant = document.getElementById(\"variantSelect\");\n  const price = parseInt(variant.selectedOptions[0].dataset.price);\n\n  \/\/ Discount Rule\n  let discount = qty * 100;\n  if (discount > 400) discount = 400;\n\n  const total = (price * qty) - discount;\n\n  document.getElementById(\"discountBox\").innerText = `You Save: Rs${discount}`;\n  document.getElementById(\"finalPriceBox\").innerText = `Final Price: Rs${total}`;\n}\n\ndocument.getElementById(\"quantityBox\").addEventListener(\"change\", updatePricing);\ndocument.getElementById(\"variantSelect\").addEventListener(\"change\", updatePricing);\n\nupdatePricing();\n\n\/\/ Order submit\ndocument.getElementById(\"codForm\").addEventListener(\"submit\", function(e) {\n  e.preventDefault();\n\n  const data = {\n    line_items: [{\n      variant_id: document.getElementById(\"variantSelect\").value,\n      quantity: document.getElementById(\"quantityBox\").value\n    }],\n    note: \n      \"Name: \" + this.name.value + \n      \"\\nPhone: \" + this.phone.value + \n      \"\\nAddress: \" + this.address.value,\n    tags: \"COD, Discount Offer\"\n  };\n\n  fetch(\"\/a\/draft_orders\", {\n    method: \"POST\",\n    headers: {\"Content-Type\":\"application\/json\"},\n    body: JSON.stringify(data)\n  })\n  .then(r => r.json())\n  .then(() => {\n    document.getElementById(\"successMsg\").style.display = \"block\";\n    this.reset();\n    updatePricing();\n  });\n});\n<\/script>"}},"custom_liquid_99gNCb":{"type":"custom_liquid","settings":{"custom_liquid":"{% comment %}\n  Trust Badges – two rows (3 badges first row, 2 badges second row)\n  Usage: {% render 'trust-badges' %}\n{% endcomment %}\n\n<style>\n  .kl-trust-badges {\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n    padding: 12px 0;\n    border-top: 1px solid rgba(0,0,0,.06);\n    border-bottom: 1px solid rgba(0,0,0,.06);\n  }\n  .kl-trust-row {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 24px;\n    flex-wrap: nowrap; \/* keep single line per row *\/\n  }\n  .kl-trust-badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 14px;\n    line-height: 1;\n    color: inherit;\n  }\n  .kl-trust-badge svg {\n    width: 20px;\n    height: 20p