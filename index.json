Id(\"popName\").innerText =\n    buyers[Math.floor(Math.random()*buyers.length)];\n\n  document.getElementById(\"popCity\").innerText =\n    cities[Math.floor(Math.random()*cities.length)];\n\n  document.getElementById(\"popTime\").innerText =\n    times[Math.floor(Math.random()*times.length)];\n\n  popup.style.display=\"block\";\n  setTimeout(()=>popup.style.display=\"none\",8000);\n}\n\n\/* Show a new popup every 12 seconds *\/\nsetInterval(showPopup,12000);\n<\/script>v","color_scheme":"","padding_top":0,"padding_bottom":0}},"collection-list":{"type":"collection-list","blocks":{"collection-0":{"type":"featured_collection","settings":{"collection":"beauty-personal-care"}},"collection-1":{"type":"featured_collection","settings":{"collection":"frontpage"}},"collection-2":{"type":"featured_collection","settings":{"collection":"tech-gagats"}},"collection-3":{"type":"featured_collection","settings":{"collection":"toys-kids"}},"featured_collection_hTYHrb":{"type":"featured_collection","disabled":true,"settings":{"collection":"hot-sellers"}}},"block_order":["collection-0","collection-1","collection-2","collection-3","featured_collection_hTYHrb"],"settings":{"title":"<em><strong>Our Collections<\/strong><\/em>","heading_size":"h0","image_ratio":"portrait","columns_desktop":4,"color_scheme":"scheme-4ee44bee-2818-4688-af1a-30fb305c176c","show_view_all":true,"columns_mobile":"1","swipe_on_mobile":false,"padding_top":16,"padding_bottom":16}},"custom_liquid_3kwJWc":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n\/* FULL-WIDTH TOP WRAPPER *\/\n.hm-top-banner-wrapper {\n  width: 100%;\n  padding: 20px 0;\n  background: linear-gradient(90deg, #8A60C2, #9C7EBB);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  box-shadow: 0 4px 20px rgba(0,0,0,0.25);\n  z-index: 9999;\n}\n\n\/* CENTERED 1550 x 200 BLOCK *\/\n.hm-banner-1550 {\n  width: 1550px;\n  height: 200px;\n  background: rgba(255,255,255,0.1);\n  border-radius: 20px;\n  color: #E7D9FE;\n  text-align: center;\n  font-family: 'Poppins', sans-serif;\n  box-shadow: 0 8px 25px rgba(0,0,0,0.25);\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  padding: 10px;\n  backdrop-filter: blur(6px);\n}\n\n\/* FLASHING TITLE *\/\n.hm-banner-title {\n  font-size: 40px;\n  font-weight: 900;\n  letter-spacing: 2px;\n  animation: blinkHM 0.8s infinite alternate;\n  text-shadow: 0 0 12px #fff;\n}\n\n@keyframes blinkHM {\n  0% { opacity: 1; text-shadow: 0 0 14px #fff; }\n  100% { opacity: .45; text-shadow: none; }\n}\n\n\/* COUNTDOWN ROW *\/\n.hm-banner-countdown {\n  display: flex;\n  justify-content: center;\n  gap: 25px;\n  margin-top: 12px;\n}\n\n.hm-box {\n  background: rgba(255,255,255,0.18);\n  padding: 12px 25px;\n  border-radius: 14px;\n  font-size: 26px;\n  font-weight: 800;\n  border: 2px solid rgba(255,255,255,0.35);\n  color: #fff;\n  min-width: 90px;\n}\n\n.hm-label {\n  font-size: 12px;\n  text-transform: uppercase;\n  color: #E7D9FE;\n  display: block;\n}\n\n\/* RESPONSIVE *\/\n@media (max-width: 900px) {\n  .hm-banner-1550 {\n    width: 95%;\n    height: auto;\n    padding: 25px 0;\n  }\n  .hm-banner-title { font-size: 28px; }\n  .hm-box { padding: 10px 18px; font-size: 20px; }\n  .hm-banner-countdown { gap: 10px; }\n}\n<\/style>\n\n<!-- ========== TOP START BANNER ========== -->\n<div class=\"hm-top-banner-wrapper\">\n  <div class=\"hm-banner-1550\">\n    <div class=\"hm-banner-title\">🔥 FLASH SALE — 50% OFF 🔥<\/div>\n\n    <div class=\"hm-banner-countdown\" id=\"hmCountdown\">\n      <div class=\"hm-box\">\n        <span id=\"hmDays\">00<\/span>\n        <span class=\"hm-label\">Days<\/span>\n      <\/div>\n      <div class=\"hm-box\">\n        <span id=\"hmHours\">00<\/span>\n        <span class=\"hm-label\">Hrs<\/span>\n      <\/div>\n      <div class=\"hm-box\">\n        <span id=\"hmMinutes\">00<\/span>\n        <span class=\"hm-label\">Min<\/span>\n      <\/div>\n      <div class=\"hm-box\">\n        <span id=\"hmSeconds\">00<\/span>\n        <span class=\"hm-label\">Sec<\/span>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nfunction startHMCountdown(endTime) {\n  function updateCountdown() {\n    const now = new Date().getTime();\n    const dist = endTime - now;\n\n    if (dist < 0) {\n      document.getElementById(\"hmCountdown\").innerHTML =\n        \"<b style='font-size:20px;'>Sale Ended!<\/b>\";\n      return;\n    }\n\n    document.getElementById(\"hmDays\").textContent =\n      Math.floor(dist \/ (1000*60*60*24)).toString().padStart(2,'0');\n    document.getElementById(\"hmHours\").textContent =\n      Math.floor((dist % (1000*60*60*24))\/(1000*60*60)).toString().padStart(2,'0');\n    document.getElementById(\"hmMinutes\").textContent =\n      Math.floor((dist % (1000*60*60))\/(1000*60)).toString().padStart(2,'0');\n    document.getElementById(\"hmSeconds\").textContent =\n      Math.floor((dist % (1000*60))\/1000).toString().padStart(2,'0');\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown, 1000);\n}\n\nlet autoHMEnd = new Date();\nautoHMEnd.setHours(autoHMEnd.getHours() + 12);\nstartHMCountdown(autoHMEnd);\n<\/script>","color_scheme":"scheme-9aaa6d23-cf58-4cd1-8221-46e31ff0062b","padding_top":40,"padding_bottom":52}},"custom_liquid_EDNT7U":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n.flash-sale-bar {\n  background: #9C7EBB;\n  color: #fff;\n  padding: 8px 0;\n  text-align: center;\n  font-family: Arial, sans-serif;\n  box-shadow: 0 0 10px rgba(0,0,0,0.3);\n}\n\n.flash-sale-bar-title {\n  font-size: 28px;\n  font-weight: 800;\n  display: inline-block;\n  margin-right: 25px;\n  animation: flashBlink 0.5s infinite alternate;\n  color: #E7D9FE;\n}\n\n@keyframes flashBlink {\n  0% { opacity: 1; text-shadow: 0 0 12px #E7D9FE; }\n  100% { opacity: 0.4; text-shadow: none; }\n}\n\n.flash-sale-bar-timer {\n  display: inline-flex;\n 